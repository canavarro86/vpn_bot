# === Telegram ===
TELEGRAM_BOT_TOKEN=
ADMIN_USER_IDS=

# === Канал для free-тира (ЗАГЛУШКА — подставить реальный ID канала) ===
REQUIRED_CHANNEL_ID=

# === Storage ===
DATA_DIR=/opt/hideway-bot/data

# === VPN-движок (Xray) ===
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
# Адрес gRPC API Xray — нужен ТОЛЬКО для StatsService (сбор трафика).
# Управление клиентами идёт через переписывание конфига + reload (см. vpn_engine/client.py).
# Для статистики включить блок "api" (StatsService) + policy stats в config.json Xray.
XRAY_API_ADDRESS=127.0.0.1:10085
SERVER_PUBLIC_IP=
REALITY_PUBLIC_KEY=
REALITY_SNI=www.swift.com
REALITY_SHORT_ID=
XHTTP_PATH=/hwapi

# === Тарифы ===
FREE_TIER_GB=5
PAID_TIER_GB=20
PAID_TIER_PRICE_USD=2.99
LOW_TRAFFIC_WARNING_MB=100

# === Платёжный шлюз (заглушка, ТЗ раздел 5) ===
PAYMENT_PROVIDER=stub

# === Rate limiting / anti-abuse ===
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60
BAN_TRIGGER=3
BAN_WINDOW=60
BAN_SECONDS=3600

# === Трафик-сэмплирование ===
TRAFFIC_SAMPLE_INTERVAL_SECONDS=300

PYTHONDONTWRITEBYTECODE=1
